{
	"Add Vue test structure": {
		"prefix": "vtest",
		"body": [
			"import { shallowMount } from '@vue/test-utils'",
			"import type { VueWrapper } from '@vue/test-utils'",
			"",
			"import $1 from '@/components/$1/index.vue'",
			"",
			"describe('$1', () => {",
			"  describe('$1 mounted', () => {",
			"    let wrapper: VueWrapper<any>",
			"    beforeEach(() => {",
			"      wrapper = shallowMount($1)",
			"    })",
			"",
			"    it('should have required elements', () => {",
			"      expect(wrapper.find('$2').exists()).toBeTruthy()",
			"    })",
			"  })",
			"})",
			""
		],
		"description": "Add Vue component test"
	},
	"Add console info": {
		"prefix": "cinfo",
		"body": ["console.info('$1', $1)"]
	},
	"Add Props interface": {
		"prefix": "eip",
		"body": [
			"export interface Props {",
			"  $1",
			"}",
			""
		]
	}
}
